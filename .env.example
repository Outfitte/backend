SERVER_PORT=8080
APP_ENV=dev
MEDIA_STORAGE_PATH=/data/media
LOG_LEVEL=info
# Required. Must be a securely generated random string, minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Database configuration
# DB_DRIVER accepts: sqlite (default), json, postgres (stub — returns unsupported error)
# DB_DSN is required for all drivers.
#
# sqlite (default): DB_DSN is the path to the SQLite database file
DB_DRIVER=sqlite
DB_DSN=/data/outfitte.db
#
# json: DB_DSN is the directory path for JSON storage files
# DB_DRIVER=json
# DB_DSN=/data/storage
#
# postgres: not yet implemented (returns unsupported driver error)
# DB_DRIVER=postgres
# DB_DSN=postgres://user:pass@host:5432/outfitte?sslmode=disable
